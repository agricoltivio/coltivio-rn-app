{
  "name": "coltivio",
  "version": "1.0.0",
  "description": "Open-source farm management app built with React Native and Expo",
  "repository": {
    "type": "git",
    "url": "https://github.com/agricoltivio/coltivio-rn-app.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "Coltivio",
  "homepage": "https://github.com/agricoltivio/coltivio-rn-app",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit && cd scripts && tsc --noEmit",
    "generate:api-types": "npx openapi-typescript ./openapi.json -o ./api/v1.d.ts",
    "eas:build-sim": "eas build -p ios --profile development-simulator",
    "eas:build-dev-ios": "eas build --profile development --platform ios",
    "eas:build-preview-ios": "eas build --profile preview --platform ios",
    "eas:build-dev-android": "APP_VARIANT=development eas build --profile development --platform android",
    "eas:install": "eas build:run -p ios",
    "expo:update": "yarn expo install expo@latest && npx expo install --fix",
    "eas:build-production": "eas build --profile production --platform all",
    "eas:submit-ios": "eas submit --platform ios --latest",
    "eas:submit-android": "eas submit --platform android --latest"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@gorhom/bottom-sheet": "^5",
    "@gorhom/portal": "^1.0.14",
    "@lukemorales/query-key-factory": "^1.3.4",
    "@maplibre/maplibre-react-native": "^11.0.0-beta.10",
    "@miblanchard/react-native-slider": "^2.6.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/elements": "^2.1.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.11.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/react-native-skia": "2.4.18",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/query-core": "^5.73.3",
    "@tanstack/react-query": "^5.59.19",
    "@turf/turf": "^7.1.0",
    "@uidotdev/usehooks": "^2.4.1",
    "date-fns": "^4.1.0",
    "expo": "^55.0.4",
    "expo-apple-authentication": "~55.0.8",
    "expo-auth-session": "~55.0.6",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.5",
    "expo-linear-gradient": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "fuse.js": "^7.0.0",
    "i18next": "^23.16.5",
    "lodash": "^4.17.21",
    "openapi-fetch": "^0.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^15.1.1",
    "react-native": "0.83.2",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.47",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "styled-components": "^6.1.13",
    "turf": "^3.0.14",
    "victory-native": "^41.12.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.13",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^18.0.7",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9.14.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.9",
    "openapi-typescript": "^7.4.3",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.7.2"
  }
}
